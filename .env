# Server
PORT=3001
NODE_ENV=development

# Database (using the working container on port 5433)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/smartshop?schema=public"

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_change_in_production
JWT_REFRESH_EXPIRES_IN=7d

# OpenAI (optional for now - leave as is or put real key later)
OPENAI_API_KEY=sk-your-openai-api-key-here
